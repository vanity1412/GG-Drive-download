{
  "manifest_version": 3,
  "name": "Google Drive URL Cleaner",
  "version": "1.0",
  "description": "Tự động xóa các tham số range, ump và srfvp từ URL Google Drive",
  "permissions": [
    "tabs",
    "downloads",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
